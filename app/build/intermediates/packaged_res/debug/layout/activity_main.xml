<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#101820">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DeepLog"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnSites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Sites"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1820">

        <TextView
            android:id="@+id/tabDownload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬇ Download"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="13sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tabDivelog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Dive Log"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="13sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tabStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Stats"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="13sp"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Tab indicator bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#1A2840">
        <View
            android:id="@+id/tabIndicator"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="#4FC3F7"/>
    </FrameLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Tab 1: Download -->
        <LinearLayout
            android:id="@+id/contentDownload"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnScan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scan"/>

                <Button
                    android:id="@+id/btnDownload"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Download"
                    android:enabled="false"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nearby devices"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:paddingTop="6dp"
                android:paddingBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1A2430"/>

        </LinearLayout>

        <!-- Tab 2: Dive Log -->
        <LinearLayout
            android:id="@+id/contentDivelog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search dives…"
                android:textColor="#EEEEEE"
                android:textColorHint="#666666"
                android:background="#1A2840"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDives"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1A2430"/>

        </LinearLayout>

        <!-- Tab 3: Stats -->
        <ScrollView
            android:id="@+id/contentStats"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"/>

        </ScrollView>

    </FrameLayout>

</LinearLayout>
