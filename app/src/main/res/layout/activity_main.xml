<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#010D1A"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DeepLog"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BLE Bridge"
        android:textSize="13sp"
        android:textColor="#3D6B8A"
        android:layout_marginBottom="48dp"/>

    <!-- Status indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_grey"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stopped"
            android:textColor="#B8DAF0"
            android:textSize="14sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Username -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="USERNAME"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textColor="#3D6B8A"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/usernameEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:textColor="#B8DAF0"
        android:textColorHint="#3D6B8A"
        android:hint="e.g. kalle"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="textNoSuggestions|textVisiblePassword"
        android:layout_marginBottom="24dp"/>

    <!-- Start / Stop -->
    <Button
        android:id="@+id/startStopBtn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Start Bridge"
        android:textColor="#010D1A"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Open web app -->
    <Button
        android:id="@+id/openWebBtn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Open DeepLog in Chrome"
        android:textColor="#00D4FF"
        android:textSize="14sp"
        android:background="@drawable/outline_btn_bg"
        android:enabled="false"/>

    <!-- Instructions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/info_box_bg"
        android:padding="16dp"
        android:layout_marginTop="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOW TO USE"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textColor="#3D6B8A"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Enter your username\n2. Tap Start Bridge\n3. Tap Open DeepLog in Chrome\n4. In DeepLog → Bridge tab → Download\n5. EON Steel shows passkey → Android dialog appears → enter passkey"
            android:textColor="#B8DAF0"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.6"
            android:fontFamily="monospace"/>
    </LinearLayout>

</LinearLayout>
